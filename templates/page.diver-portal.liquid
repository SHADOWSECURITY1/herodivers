<!-- Hero section -->
<section class="page-hero" style="position:relative; min-height:60vh; display:flex; align-items:center; background:linear-gradient(180deg, var(--abyss) 0%, var(--ocean) 60%, var(--deep) 100%); overflow:hidden;">
  <div class="god-rays">
    <div class="god-ray"></div>
    <div class="god-ray"></div>
    <div class="god-ray"></div>
    <div class="god-ray"></div>
  </div>
  <div class="bubbles" id="heroBubbles" data-bubbles="14"></div>
  <div class="plankton-field" id="heroPlankton" data-plankton="20"></div>

  <div class="content-wrap" style="position:relative; z-index:10; padding-top:120px; padding-bottom:80px;">
    <div class="section-tag reveal">Professional Network</div>
    <h1 class="reveal reveal-delay-1" style="font-family:'Oswald',sans-serif; font-weight:700; font-size:clamp(40px,6vw,72px); letter-spacing:3px; text-transform:uppercase; line-height:1; margin-bottom:24px;">
      The Hero<br><span style="color:var(--cyan);">Diver Portal</span>
    </h1>
    <p class="reveal reveal-delay-2" style="font-size:18px; color:var(--fog); max-width:560px; line-height:1.7; margin-bottom:40px;">
      A global network of certified divers delivering standardized underwater inspection and cleaning services — powered by Hero Diving & Marine Services.
    </p>
    <div class="reveal reveal-delay-3" style="display:flex; gap:16px; flex-wrap:wrap;">
      <a href="https://hero-diver-portal.netlify.app/signup.html" class="btn-primary">Create Account →</a>
      <a href="https://hero-diver-portal.netlify.app" class="btn-ghost">Sign In</a>
    </div>
  </div>
</section>

<!-- What is the portal -->
<section class="content-section dark" style="position:relative; padding:80px 0; background:var(--deep);">
  <div class="god-rays" style="opacity:0.4;"></div>
  <div class="bubbles" id="b1" data-bubbles="8"></div>
  <div class="content-wrap" style="position:relative; z-index:2;">
    <div class="section-tag reveal">How It Works</div>
    <h2 class="reveal reveal-delay-1" style="font-family:'Oswald',sans-serif; font-weight:700; font-size:clamp(28px,4vw,48px); letter-spacing:2px; text-transform:uppercase; margin-bottom:48px;">
      Standardized Reports.<br>Global Coverage.
    </h2>

    <div class="feature-grid reveal reveal-delay-2">
      <div class="feature-card">
        <span class="icon">🌊</span>
        <h3>Anywhere in the World</h3>
        <p>Hero-certified divers operate globally. Submit an inspection request and we connect you with a qualified diver in your location.</p>
      </div>
      <div class="feature-card">
        <span class="icon">📋</span>
        <h3>Standardized Reporting</h3>
        <p>Every inspection follows the Hero standard — hull condition, running gear, anodes, through-hulls, and dive conditions documented in a consistent format.</p>
      </div>
      <div class="feature-card">
        <span class="icon">📧</span>
        <h3>Delivered to Your Inbox</h3>
        <p>Completed reports are emailed directly to you as a professional branded document the moment the dive is complete.</p>
      </div>
      <div class="feature-card">
        <span class="icon">🎖️</span>
        <h3>Certified Professionals</h3>
        <p>Every diver in the Hero network holds current commercial certifications and operates under Hero's standards for safety and reporting.</p>
      </div>
    </div>
  </div>
</section>

<!-- For Divers section -->
<section style="position:relative; padding:80px 0; background:var(--ocean); overflow:hidden;">
  <div class="bubbles" id="b2" data-bubbles="10"></div>
  <div class="content-wrap" style="position:relative; z-index:2;">
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:64px; align-items:center;">
      <div>
        <div class="section-tag reveal">For Divers</div>
        <h2 class="reveal reveal-delay-1" style="font-family:'Oswald',sans-serif; font-weight:700; font-size:clamp(28px,3vw,42px); letter-spacing:2px; text-transform:uppercase; margin-bottom:20px;">
          Join the Hero<br>Diver Network
        </h2>
        <p class="reveal reveal-delay-2" style="color:var(--fog); font-size:16px; line-height:1.7; margin-bottom:32px;">
          Are you a certified commercial diver? Join our global network and access jobs in your area. Hero handles the client relationships, standardized reporting tools, and payment processing — you focus on the dive.
        </p>
        <ul class="reveal reveal-delay-3" style="list-style:none; margin-bottom:36px;">
          <li style="padding:10px 0; border-bottom:1px solid var(--border); color:var(--fog); display:flex; gap:12px; align-items:center;">
            <span style="color:var(--cyan);">✓</span> Access to the Hero reporting platform
          </li>
          <li style="padding:10px 0; border-bottom:1px solid var(--border); color:var(--fog); display:flex; gap:12px; align-items:center;">
            <span style="color:var(--cyan);">✓</span> Standardized inspection forms & email delivery
          </li>
          <li style="padding:10px 0; border-bottom:1px solid var(--border); color:var(--fog); display:flex; gap:12px; align-items:center;">
            <span style="color:var(--cyan);">✓</span> Hero-branded reports sent on your behalf
          </li>
          <li style="padding:10px 0; color:var(--fog); display:flex; gap:12px; align-items:center;">
            <span style="color:var(--cyan);">✓</span> Competitive commission structure
          </li>
        </ul>
        <a href="/pages/contact" class="btn-primary reveal reveal-delay-4">Apply to Join</a>
      </div>
      <div class="reveal reveal-delay-2">
        <img src="{{ 'navydivers.png' | asset_url }}" alt="Hero Divers" style="width:100%; display:block;">
      </div>
    </div>
  </div>
</section>

<!-- For Vessel Owners -->
<section style="position:relative; padding:80px 0; background:var(--deep); overflow:hidden;">
  <div class="bubbles" id="b3" data-bubbles="8"></div>
  <div class="content-wrap" style="position:relative; z-index:2;">
    <div class="section-tag reveal" style="text-align:center;">For Marine Clients</div>
    <h2 class="reveal reveal-delay-1" style="font-family:'Oswald',sans-serif; font-weight:700; font-size:clamp(28px,3vw,42px); letter-spacing:2px; text-transform:uppercase; text-align:center; margin-bottom:16px;">
      Need an Inspection?
    </h2>
    <p class="reveal reveal-delay-2" style="text-align:center; color:var(--fog); font-size:16px; max-width:520px; margin:0 auto 48px; line-height:1.7;">
      Vessel hull, dock pilings, marina jetty — wherever it is and whatever it is, request a Hero-standard inspection and receive a professional report within 24 hours.
    </p>
    <div style="text-align:center;" class="reveal reveal-delay-3">
      <a href="/pages/request-inspection" class="btn-primary">Request an Inspection</a>
    </div>
  </div>
</section>

<!-- CTA band -->
<section class="cta-band" style="position:relative; padding:80px 0; background:var(--signal-red); overflow:hidden; text-align:center;">
  <div class="god-rays"></div>
  <div style="position:relative; z-index:2;">
    <h2 class="reveal" style="font-family:'Oswald',sans-serif; font-weight:700; font-size:clamp(28px,4vw,48px); letter-spacing:3px; text-transform:uppercase; margin-bottom:16px;">Ready to Dive In?</h2>
    <p class="reveal reveal-delay-1" style="color:rgba(240,244,248,0.8); font-size:18px; margin-bottom:36px;">New to Hero Divers? Create your account and start accepting jobs.</p>
    <div class="reveal reveal-delay-2" style="display:flex; gap:16px; justify-content:center; flex-wrap:wrap;">
      <a href="https://hero-diver-portal.netlify.app/signup.html" style="display:inline-block; padding:16px 48px; background:var(--white); color:var(--signal-red); font-family:'Oswald',sans-serif; font-weight:700; font-size:15px; letter-spacing:3px; text-transform:uppercase; text-decoration:none; clip-path:polygon(0 0, 100% 0, 96% 100%, 0 100%); padding-right:56px;">Create Account</a>
      <a href="https://hero-diver-portal.netlify.app" style="display:inline-block; padding:16px 40px; border:2px solid rgba(255,255,255,0.5); color:var(--white); font-family:'Oswald',sans-serif; font-weight:700; font-size:15px; letter-spacing:3px; text-transform:uppercase; text-decoration:none;">Sign In</a>
    </div>
  </div>
</section>
