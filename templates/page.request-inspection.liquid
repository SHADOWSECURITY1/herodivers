<!-- Hero section -->
<section class="page-hero" style="position:relative; min-height:65vh; display:flex; align-items:center; background:linear-gradient(180deg, var(--abyss) 0%, var(--ocean) 60%, var(--deep) 100%); overflow:hidden;">
  <div class="god-rays">
    <div class="god-ray"></div>
    <div class="god-ray"></div>
    <div class="god-ray"></div>
    <div class="god-ray"></div>
  </div>
  <div class="bubbles" id="heroBubbles" data-bubbles="14"></div>
  <div class="plankton-field" id="heroPlankton" data-plankton="20"></div>

  <div class="content-wrap" style="position:relative; z-index:10; padding-top:120px; padding-bottom:80px;">
    <div class="section-tag reveal">Marine Clients</div>
    <h1 class="reveal reveal-delay-1" style="font-family:'Oswald',sans-serif; font-weight:700; font-size:clamp(40px,6vw,72px); letter-spacing:3px; text-transform:uppercase; line-height:1; margin-bottom:24px;">
      Request an<br><span style="color:var(--cyan);">Inspection</span>
    </h1>
    <p class="reveal reveal-delay-2" style="font-size:18px; color:var(--fog); max-width:580px; line-height:1.7; margin-bottom:40px;">
      Vessel hull. Marina jetty. Dock pilings. Seawall. Whatever's underwater — Hero-certified divers inspect it, document it, and deliver a professional report to your inbox.
    </p>
    <div class="reveal reveal-delay-3" style="display:flex; gap:16px; flex-wrap:wrap;">
      <a href="https://hero-diver-portal.netlify.app/signup.html" class="btn-primary">Get Started →</a>
      <a href="https://hero-diver-portal.netlify.app" class="btn-ghost">Sign In</a>
    </div>
  </div>
</section>

<!-- What we inspect -->
<section style="position:relative; padding:80px 0; background:var(--deep); overflow:hidden;">
  <div class="god-rays" style="opacity:0.3;"></div>
  <div class="bubbles" id="b1" data-bubbles="8"></div>
  <div class="content-wrap" style="position:relative; z-index:2;">
    <div class="section-tag reveal" style="text-align:center;">What We Inspect</div>
    <h2 class="reveal reveal-delay-1" style="font-family:'Oswald',sans-serif; font-weight:700; font-size:clamp(28px,4vw,48px); letter-spacing:2px; text-transform:uppercase; text-align:center; margin-bottom:48px;">
      If It's Underwater,<br>We Can Inspect It.
    </h2>

    <div class="feature-grid reveal reveal-delay-2">
      <div class="feature-card">
        <span class="icon">⚓</span>
        <h3>Vessels & Hulls</h3>
        <p>Full hull condition surveys — marine growth, antifouling, blistering, running gear, anodes, through-hulls. Sailboats to superyachts.</p>
      </div>
      <div class="feature-card">
        <span class="icon">🏗️</span>
        <h3>Docks & Jetties</h3>
        <p>Underwater structural inspection of dock pilings, cross-bracing, bolts, and decking supports. Know what's deteriorating before it fails.</p>
      </div>
      <div class="feature-card">
        <span class="icon">🌊</span>
        <h3>Marina Infrastructure</h3>
        <p>Seawalls, breakwaters, mooring blocks, and marina basin surveys. Complete condition reports for insurance, maintenance planning, or sale.</p>
      </div>
      <div class="feature-card">
        <span class="icon">🔩</span>
        <h3>Custom Marine Ops</h3>
        <p>Lost items, debris removal, prop entanglement, zinc replacement, through-hull inspection — if it needs a diver, we can dispatch one.</p>
      </div>
    </div>
  </div>
</section>

<!-- How it works -->
<section style="position:relative; padding:80px 0; background:var(--ocean); overflow:hidden;">
  <div class="bubbles" id="b2" data-bubbles="10"></div>
  <div class="content-wrap" style="position:relative; z-index:2;">
    <div class="section-tag reveal" style="text-align:center;">How It Works</div>
    <h2 class="reveal reveal-delay-1" style="font-family:'Oswald',sans-serif; font-weight:700; font-size:clamp(28px,4vw,48px); letter-spacing:2px; text-transform:uppercase; text-align:center; margin-bottom:64px;">
      Four Steps.<br>One Report.
    </h2>

    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(220px, 1fr)); gap:32px; max-width:900px; margin:0 auto;" class="reveal reveal-delay-2">

      <div style="text-align:center;">
        <div style="width:56px; height:56px; background:rgba(0,212,255,0.1); border:1px solid rgba(0,212,255,0.3); display:flex; align-items:center; justify-content:center; margin:0 auto 20px; font-family:'Oswald',sans-serif; font-weight:700; font-size:22px; color:var(--cyan);">01</div>
        <h4 style="font-family:'Oswald',sans-serif; font-size:16px; letter-spacing:2px; text-transform:uppercase; margin-bottom:10px;">Create Account</h4>
        <p style="color:var(--fog); font-size:14px; line-height:1.7;">Sign up as a Marine Client in under two minutes. No commitment required.</p>
      </div>

      <div style="text-align:center;">
        <div style="width:56px; height:56px; background:rgba(0,212,255,0.1); border:1px solid rgba(0,212,255,0.3); display:flex; align-items:center; justify-content:center; margin:0 auto 20px; font-family:'Oswald',sans-serif; font-weight:700; font-size:22px; color:var(--cyan);">02</div>
        <h4 style="font-family:'Oswald',sans-serif; font-size:16px; letter-spacing:2px; text-transform:uppercase; margin-bottom:10px;">Request & Pay</h4>
        <p style="color:var(--fog); font-size:14px; line-height:1.7;">Describe what needs inspecting, pick a date, and pay securely upfront via Stripe.</p>
      </div>

      <div style="text-align:center;">
        <div style="width:56px; height:56px; background:rgba(0,212,255,0.1); border:1px solid rgba(0,212,255,0.3); display:flex; align-items:center; justify-content:center; margin:0 auto 20px; font-family:'Oswald',sans-serif; font-weight:700; font-size:22px; color:var(--cyan);">03</div>
        <h4 style="font-family:'Oswald',sans-serif; font-size:16px; letter-spacing:2px; text-transform:uppercase; margin-bottom:10px;">Diver Dispatched</h4>
        <p style="color:var(--fog); font-size:14px; line-height:1.7;">A certified Hero diver in your area accepts the job and contacts you to confirm details.</p>
      </div>

      <div style="text-align:center;">
        <div style="width:56px; height:56px; background:rgba(0,212,255,0.1); border:1px solid rgba(0,212,255,0.3); display:flex; align-items:center; justify-content:center; margin:0 auto 20px; font-family:'Oswald',sans-serif; font-weight:700; font-size:22px; color:var(--cyan);">04</div>
        <h4 style="font-family:'Oswald',sans-serif; font-size:16px; letter-spacing:2px; text-transform:uppercase; margin-bottom:10px;">Report Delivered</h4>
        <p style="color:var(--fog); font-size:14px; line-height:1.7;">A professional Hero-branded report lands in your inbox the moment the dive is complete.</p>
      </div>

    </div>
  </div>
</section>

<!-- Pricing overview -->
<section style="position:relative; padding:80px 0; background:var(--deep); overflow:hidden;">
  <div class="bubbles" id="b3" data-bubbles="6"></div>
  <div class="content-wrap" style="position:relative; z-index:2;">
    <div class="section-tag reveal" style="text-align:center;">Transparent Pricing</div>
    <h2 class="reveal reveal-delay-1" style="font-family:'Oswald',sans-serif; font-weight:700; font-size:clamp(28px,4vw,48px); letter-spacing:2px; text-transform:uppercase; text-align:center; margin-bottom:16px;">
      Flat Rates. No Surprises.
    </h2>
    <p class="reveal reveal-delay-2" style="text-align:center; color:var(--fog); font-size:16px; max-width:520px; margin:0 auto 48px; line-height:1.7;">
      Every service is priced upfront. No quotes, no negotiations, no hidden fees.
    </p>

    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(200px, 1fr)); gap:2px; max-width:900px; margin:0 auto;" class="reveal reveal-delay-2">

      {% assign services = "Hull Inspection|$199,Hull Cleaning|$299,Full Underwater Survey|$499,Propeller Check|$149,Anode Check & Replacement|$149,Zinc Replacement|$199,Custom Request|from $249" | split: "," %}
      {% for svc in services %}
        {% assign parts = svc | split: "|" %}
        <div style="background:var(--card-bg); border:1px solid var(--border); padding:24px 20px; display:flex; flex-direction:column; gap:8px;">
          <div style="font-family:'Barlow Condensed',sans-serif; font-size:11px; letter-spacing:3px; text-transform:uppercase; color:var(--fog);">{{ parts[0] }}</div>
          <div style="font-family:'Oswald',sans-serif; font-weight:700; font-size:28px; color:var(--cyan);">{{ parts[1] }}</div>
        </div>
      {% endfor %}

    </div>

    <p class="reveal reveal-delay-3" style="text-align:center; color:var(--fog); font-size:13px; margin-top:24px;">
      All prices are platform rates. Payment processed securely via Stripe.
    </p>
  </div>
</section>

