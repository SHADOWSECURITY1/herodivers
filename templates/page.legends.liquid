<style>
  /* ═══════════════════════════════════════════
     20,000 LEAGUES AESTHETIC OVERRIDES
     Brass, rivets, portholes, deep sea wonder
     ═══════════════════════════════════════════ */

  :root {
    --brass: #b8943e;
    --brass-light: #d4af5a;
    --brass-dark: #8a6d2b;
    --patina: #4a7a6a;
    --copper: #b87333;
    --parchment: #e8dcc8;
    --ink: #1a1812;
  }

  .porthole-img {
    position: absolute;
    top: 6px; left: 6px;
    width: calc(100% - 12px);
    height: calc(100% - 12px);
    border-radius: 50%;
    object-fit: cover;
    object-position: center 20%;
    z-index: 2;
    filter: saturate(0.7) contrast(1.1);
    opacity: 0.85;
    transition: all 0.5s ease;
  }

  .legend-card:hover .porthole-img {
    filter: saturate(1) contrast(1.1);
    opacity: 1;
  }

  /* ── PORTHOLE CARD ── */
  .legend-card {
    position: relative;
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 48px;
    align-items: center;
    padding: 56px 48px;
    margin-bottom: 2px;
    background: rgba(8,24,48,0.6);
    border: 1px solid rgba(184,148,62,0.1);
    backdrop-filter: blur(8px);
    transition: all 0.5s ease;
    overflow: hidden;
  }

  .legend-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 4px; height: 100%;
    background: linear-gradient(180deg, var(--brass), var(--brass-dark), transparent);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 0.5s ease;
  }

  .legend-card:hover::before { transform: scaleY(1); }

  .legend-card:hover {
    background: rgba(184,148,62,0.04);
    border-color: rgba(184,148,62,0.2);
  }

  /* Brass rivets on card corners */
  .legend-card::after {
    content: '';
    position: absolute;
    top: 12px; right: 12px;
    width: 8px; height: 8px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 35%, var(--brass-light), var(--brass-dark));
    box-shadow:
      0 0 0 1px rgba(184,148,62,0.3),
      calc(-100% + 24px) 0 0 0 transparent;
  }

  /* ── PORTHOLE FRAME ── */
  .porthole {
    position: relative;
    width: 200px;
    height: 200px;
    flex-shrink: 0;
  }

  .porthole-frame {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 6px solid var(--brass);
    background: radial-gradient(circle at 40% 35%,
      rgba(0,212,255,0.08) 0%,
      rgba(12,35,64,0.9) 50%,
      rgba(4,8,16,0.95) 100%
    );
    box-shadow:
      inset 0 0 30px rgba(0,0,0,0.5),
      inset 0 0 60px rgba(0,212,255,0.05),
      0 0 20px rgba(184,148,62,0.1);
    overflow: hidden;
  }

  /* Glass reflection */
  .porthole-frame::before {
    content: '';
    position: absolute;
    top: 8%; left: 12%;
    width: 35%; height: 20%;
    background: linear-gradient(135deg, rgba(255,255,255,0.08), transparent);
    border-radius: 50%;
    transform: rotate(-20deg);
  }

  /* Water caustic inside porthole */
  .porthole-frame::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background:
      radial-gradient(ellipse at 60% 70%, rgba(0,212,255,0.06) 0%, transparent 50%);
    animation: portholeCaustic 6s ease-in-out infinite;
  }

  @keyframes portholeCaustic {
    0%, 100% { opacity: 0.5; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.1) rotate(5deg); }
  }

  /* Bolts around porthole */
  .porthole-bolts {
    position: absolute;
    inset: -3px;
  }

  .porthole-bolt {
    position: absolute;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 35%, var(--brass-light), var(--brass-dark));
    border: 1px solid rgba(184,148,62,0.4);
  }

  .porthole-bolt:nth-child(1) { top: 5%; left: 50%; transform: translateX(-50%); }
  .porthole-bolt:nth-child(2) { top: 50%; right: 3%; transform: translateY(-50%); }
  .porthole-bolt:nth-child(3) { bottom: 5%; left: 50%; transform: translateX(-50%); }
  .porthole-bolt:nth-child(4) { top: 50%; left: 3%; transform: translateY(-50%); }
  .porthole-bolt:nth-child(5) { top: 15%; right: 12%; }
  .porthole-bolt:nth-child(6) { bottom: 15%; right: 12%; }
  .porthole-bolt:nth-child(7) { bottom: 15%; left: 12%; }
  .porthole-bolt:nth-child(8) { top: 15%; left: 12%; }

  .porthole-icon {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    font-size: 64px;
    z-index: 2;
    filter: drop-shadow(0 4px 12px rgba(0,0,0,0.4));
  }

  /* ── LEGEND INFO ── */
  .legend-info { position: relative; z-index: 2; }

  .legend-era {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--brass);
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .legend-era::before {
    content: '';
    width: 20px; height: 1px;
    background: var(--brass);
  }

  .legend-name {
    font-family: 'Oswald', sans-serif;
    font-weight: 700;
    font-size: clamp(28px, 3vw, 42px);
    line-height: 1.05;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 6px;
    transition: color 0.3s ease;
  }

  .legend-card:hover .legend-name { color: var(--brass-light); }

  .legend-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 400;
    font-size: 15px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--cyan);
    margin-bottom: 16px;
  }

  .legend-bio {
    font-weight: 300;
    font-size: 16px;
    line-height: 1.75;
    color: var(--fog);
    margin-bottom: 20px;
    max-width: 600px;
  }

  .legend-feats {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .legend-feat {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--brass);
    padding: 5px 14px;
    border: 1px solid rgba(184,148,62,0.2);
    background: rgba(184,148,62,0.04);
  }

  /* ── ERA DIVIDER ── */
  .era-divider {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 48px 0 24px;
    max-width: 1000px;
    margin: 0 auto;
  }

  .era-divider-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(184,148,62,0.3), transparent);
  }

  .era-divider-label {
    font-family: 'Oswald', sans-serif;
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 5px;
    text-transform: uppercase;
    color: var(--brass);
    white-space: nowrap;
  }

  /* ── NAUTICAL COMPASS HERO ELEMENT ── */
  .compass-container {
    position: absolute;
    right: 5%;
    top: 50%;
    transform: translateY(-50%);
    width: 400px;
    height: 400px;
    opacity: 0.04;
    z-index: 1;
  }

  .compass-ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid var(--brass);
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
  }

  .compass-ring:nth-child(1) {
    width: 100%; height: 100%;
    animation: compassSpin 40s linear infinite;
  }

  .compass-ring:nth-child(2) {
    width: 70%; height: 70%;
    border-style: dashed;
    animation: compassSpin 30s linear infinite reverse;
  }

  .compass-ring:nth-child(3) {
    width: 40%; height: 40%;
    animation: compassSpin 20s linear infinite;
  }

  @keyframes compassSpin {
    from { transform: translate(-50%, -50%) rotate(0deg); }
    to { transform: translate(-50%, -50%) rotate(360deg); }
  }

  /* ── VINTAGE QUOTE BLOCK ── */
  .vintage-quote {
    text-align: center;
    padding: 80px 48px;
    position: relative;
    overflow: hidden;
    background: linear-gradient(180deg, rgba(184,148,62,0.02) 0%, transparent 50%, rgba(184,148,62,0.02) 100%);
    border-top: 1px solid rgba(184,148,62,0.08);
    border-bottom: 1px solid rgba(184,148,62,0.08);
    margin: 0 auto;
    max-width: 1000px;
  }

  .vintage-quote blockquote {
    font-family: 'Oswald', sans-serif;
    font-weight: 600;
    font-size: clamp(22px, 3vw, 36px);
    line-height: 1.3;
    text-transform: uppercase;
    color: var(--parchment);
    max-width: 700px;
    margin: 0 auto 16px;
    position: relative;
    z-index: 2;
  }

  .vintage-quote blockquote .em {
    color: var(--brass-light);
    font-style: normal;
  }

  .vintage-quote cite {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 400;
    font-size: 13px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--fog);
    font-style: normal;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .legend-card {
      grid-template-columns: 1fr;
      text-align: center;
      padding: 40px 24px;
      gap: 24px;
    }
    .porthole { margin: 0 auto; width: 160px; height: 160px; }
    .legend-era { justify-content: center; }
    .legend-feats { justify-content: center; }
    .legend-bio { max-width: 100%; }
    .compass-container { display: none; }
  }
</style>

