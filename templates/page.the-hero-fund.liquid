<style>
  :root {
    --gold: #D4A843;
    --gold-dim: rgba(212,168,67,0.15);
    --gold-glow: rgba(212,168,67,0.08);
    --fund-dark: #0A0A0F;
    --fund-deep: #111118;
    --fund-card: #141420;
    --fund-border: rgba(212,168,67,0.12);
  }

  .fund-page { background: var(--fund-dark); color: var(--white); font-family: 'Barlow', sans-serif; }

  /* ═══ HERO ═══ */
  .fund-hero {
    min-height: 85vh;
    display: flex; align-items: center; justify-content: center;
    text-align: center;
    padding: 140px 48px 100px;
    position: relative; overflow: hidden;
    background: radial-gradient(ellipse at 50% 0%, rgba(212,168,67,0.12) 0%, transparent 60%),
                linear-gradient(180deg, #060609 0%, #0A0A0F 100%);
  }

  .fund-hero-badge {
    display: inline-flex; align-items: center; gap: 10px;
    font-family: 'Barlow Condensed', sans-serif; font-size: 12px;
    letter-spacing: 4px; text-transform: uppercase;
    color: var(--gold); border: 1px solid var(--fund-border);
    padding: 8px 20px; margin-bottom: 36px;
  }

  .fund-hero-badge::before {
    content: ''; width: 6px; height: 6px;
    background: var(--gold); border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse { 0%,100% { opacity:1; transform:scale(1); } 50% { opacity:0.5; transform:scale(1.4); } }

  .fund-hero h1 {
    font-family: 'Oswald', sans-serif; font-weight: 700;
    font-size: clamp(52px, 8vw, 110px);
    line-height: 0.9; text-transform: uppercase; letter-spacing: -2px;
    margin-bottom: 28px;
  }

  .fund-hero h1 em { font-style: normal; color: var(--gold); }

  .fund-hero-sub {
    font-weight: 300; font-size: 20px; line-height: 1.7;
    color: var(--fog); max-width: 640px; margin: 0 auto 48px;
  }

  .fund-hero-actions { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }

  .btn-gold {
    display: inline-block; padding: 16px 48px;
    background: var(--gold); color: #0A0A0F;
    font-family: 'Oswald', sans-serif; font-weight: 700;
    font-size: 14px; letter-spacing: 3px; text-transform: uppercase;
    text-decoration: none; transition: all 0.3s ease;
    clip-path: polygon(0 0, 100% 0, 96% 100%, 0 100%);
    padding-right: 56px;
  }

  .btn-gold:hover { background: #e8ba50; transform: translateY(-2px); box-shadow: 0 8px 32px rgba(212,168,67,0.3); color: #0A0A0F; }

  .btn-fund-ghost {
    display: inline-block; padding: 16px 36px;
    background: transparent; color: var(--white);
    font-family: 'Barlow Condensed', sans-serif; font-weight: 500;
    font-size: 14px; letter-spacing: 3px; text-transform: uppercase;
    text-decoration: none; border: 1px solid rgba(240,244,248,0.2);
    transition: all 0.3s ease;
  }

  .btn-fund-ghost:hover { border-color: var(--gold); color: var(--gold); background: var(--gold-glow); }

  /* ═══ STATS BAR ═══ */
  .fund-stats {
    background: var(--fund-deep);
    border-top: 1px solid var(--fund-border);
    border-bottom: 1px solid var(--fund-border);
    padding: 48px;
    display: flex; justify-content: center; gap: 0; flex-wrap: wrap;
  }

  .fund-stat {
    text-align: center; flex: 1; min-width: 160px;
    padding: 0 32px;
    border-right: 1px solid var(--fund-border);
  }

  .fund-stat:last-child { border-right: none; }

  .fund-stat-num {
    font-family: 'Oswald', sans-serif; font-weight: 700;
    font-size: 52px; line-height: 1; color: var(--gold); margin-bottom: 6px;
  }

  .fund-stat-label {
    font-family: 'Barlow Condensed', sans-serif; font-weight: 400;
    font-size: 12px; letter-spacing: 3px; text-transform: uppercase; color: var(--fog);
  }

  /* ═══ SECTIONS ═══ */
  .fund-section {
    padding: 100px 48px;
    position: relative; overflow: hidden;
  }

  .fund-section.dark { background: var(--fund-dark); }
  .fund-section.deep { background: var(--fund-deep); }

  .fund-wrap { max-width: 1100px; margin: 0 auto; position: relative; z-index: 5; }

  .fund-section-tag {
    font-family: 'Barlow Condensed', sans-serif; font-weight: 500;
    font-size: 13px; letter-spacing: 5px; text-transform: uppercase;
    color: var(--gold); display: flex; align-items: center; gap: 16px;
    margin-bottom: 16px;
  }

  .fund-section-tag::before { content: ''; width: 30px; height: 1px; background: var(--gold); }

  .fund-section h2 {
    font-family: 'Oswald', sans-serif; font-weight: 700;
    font-size: clamp(36px, 5vw, 68px); line-height: 0.95;
    text-transform: uppercase; letter-spacing: -1px; margin-bottom: 24px;
  }

  .fund-section h2 em { font-style: normal; color: var(--gold); }

  .fund-section p {
    font-weight: 300; font-size: 18px; line-height: 1.8;
    color: var(--fog); max-width: 680px; margin-bottom: 20px;
  }

  .fund-section p strong { color: var(--white); font-weight: 500; font-style: italic; }

  /* ═══ HERO PILLARS ═══ */
  .hero-pillars {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 2px; margin-top: 48px;
  }

  .hero-pillar {
    background: var(--fund-card);
    border: 1px solid var(--fund-border);
    padding: 32px 24px; text-align: center;
    transition: all 0.3s ease;
  }

  .hero-pillar:hover { border-color: var(--gold); background: var(--gold-glow); }

  .pillar-letter {
    font-family: 'Oswald', sans-serif; font-weight: 700;
    font-size: 72px; line-height: 1; color: var(--gold);
    opacity: 0.8; margin-bottom: 12px;
  }

  .pillar-word {
    font-family: 'Oswald', sans-serif; font-weight: 600;
    font-size: 18px; text-transform: uppercase; letter-spacing: 2px;
    color: var(--white); margin-bottom: 10px;
  }

  .pillar-desc {
    font-size: 14px; line-height: 1.6; color: var(--fog); margin: 0;
  }

  /* ═══ PROCESS STEPS ═══ */
  .fund-steps {
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: 2px; margin-top: 48px;
  }

  .fund-step {
    background: var(--fund-card);
    border: 1px solid var(--fund-border);
    padding: 40px 36px;
    position: relative; overflow: hidden;
    transition: all 0.4s ease;
  }

  .fund-step:hover { border-color: var(--gold); }

  .fund-step::before {
    content: ''; position: absolute; top: 0; left: 0;
    width: 100%; height: 3px;
    background: linear-gradient(90deg, var(--gold), transparent);
    transform: scaleX(0); transform-origin: left;
    transition: transform 0.4s ease;
  }

  .fund-step:hover::before { transform: scaleX(1); }

  .step-num {
    font-family: 'Oswald', sans-serif; font-weight: 700;
    font-size: 64px; line-height: 1; color: rgba(212,168,67,0.1);
    margin-bottom: 8px;
  }

  .step-icon { font-size: 28px; margin-bottom: 12px; display: block; }

  .fund-step h3 {
    font-family: 'Oswald', sans-serif; font-weight: 600;
    font-size: 20px; text-transform: uppercase; letter-spacing: 2px;
    color: var(--gold); margin-bottom: 12px;
  }

  .fund-step p { font-size: 15px; line-height: 1.7; color: var(--fog); margin: 0; }

  /* ═══ SERVICES GRID ═══ */
  .services-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 2px; margin-top: 48px;
  }

  .service-card {
    background: var(--fund-card);
    border: 1px solid var(--fund-border);
    padding: 36px 32px;
    transition: all 0.3s ease;
  }

  .service-card:hover { border-color: var(--gold); background: var(--gold-glow); transform: translateY(-3px); }

  .service-icon { font-size: 32px; margin-bottom: 16px; display: block; }

  .service-card h3 {
    font-family: 'Oswald', sans-serif; font-weight: 600;
    font-size: 18px; text-transform: uppercase; letter-spacing: 1px;
    color: var(--white); margin-bottom: 10px;
  }

  .service-card p { font-size: 14px; line-height: 1.7; color: var(--fog); margin: 0; }

  /* ═══ DEAL STRUCTURE ═══ */
  .deal-grid {
    display: grid; grid-template-columns: 1fr auto 1fr;
    gap: 0; margin-top: 48px; align-items: stretch;
  }

  .deal-col {
    background: var(--fund-card);
    border: 1px solid var(--fund-border);
    padding: 48px 40px;
  }

  .deal-col h3 {
    font-family: 'Oswald', sans-serif; font-weight: 600;
    font-size: 22px; text-transform: uppercase; letter-spacing: 2px;
    color: var(--gold); margin-bottom: 28px;
  }

  .deal-item {
    display: flex; align-items: flex-start; gap: 12px;
    margin-bottom: 16px; font-size: 15px; color: var(--fog); line-height: 1.5;
  }

  .deal-item::before {
    content: '✦'; color: var(--gold); font-size: 10px;
    flex-shrink: 0; margin-top: 4px;
  }

  .deal-center {
    display: flex; align-items: center; justify-content: center;
    padding: 0 32px;
    background: linear-gradient(180deg, var(--fund-dark), var(--fund-deep));
    border-top: 1px solid var(--fund-border);
    border-bottom: 1px solid var(--fund-border);
  }

  .equity-badge {
    text-align: center;
    border: 2px solid var(--gold);
    padding: 24px 20px;
    min-width: 120px;
  }

  .equity-pct {
    font-family: 'Oswald', sans-serif; font-weight: 700;
    font-size: 42px; line-height: 1; color: var(--gold);
  }

  .equity-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px; letter-spacing: 3px; text-transform: uppercase;
    color: var(--fog); margin-top: 6px;
  }

  /* ═══ CTA BAND ═══ */
  .fund-cta {
    padding: 120px 48px;
    text-align: center;
    position: relative; overflow: hidden;
    background: radial-gradient(ellipse at 50% 50%, rgba(212,168,67,0.08) 0%, transparent 60%),
                linear-gradient(180deg, var(--fund-deep), var(--fund-dark));
  }

  .fund-cta h2 {
    font-family: 'Oswald', sans-serif; font-weight: 700;
    font-size: clamp(44px, 6vw, 80px); line-height: 0.95;
    text-transform: uppercase; letter-spacing: -2px; margin-bottom: 20px;
  }

  .fund-cta p {
    font-weight: 300; font-size: 18px; color: var(--fog);
    max-width: 520px; margin: 0 auto 40px; line-height: 1.6;
  }

  .fund-cta-buttons { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }

  @media (max-width: 768px) {
    .fund-hero { padding: 120px 24px 80px; }
    .fund-stats { padding: 32px 24px; flex-direction: column; }
    .fund-stat { border-right: none; border-bottom: 1px solid var(--fund-border); padding: 24px 0; }
    .fund-stat:last-child { border-bottom: none; }
    .fund-section { padding: 64px 24px; }
    .hero-pillars { grid-template-columns: repeat(2, 1fr); }
    .fund-steps { grid-template-columns: 1fr; }
    .services-grid { grid-template-columns: 1fr; }
    .deal-grid { grid-template-columns: 1fr; }
    .deal-center { padding: 32px 24px; }
  }
</style>

<div class="fund-page">

